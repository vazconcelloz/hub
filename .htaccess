# Forçar o sistema a usar apenas 1 processo (economiza memória e evita o limite de 40 no cPanel)
PassengerMinInstances 1
PassengerMaxInstances 1
PassengerPoolIdleTimeout 60

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Ignorar chamadas da API (deixar o Node.js lidar)
  RewriteRule ^api/ - [L]

  # 2. Se pedir a raiz (/), entregar o index.html da dist
  RewriteRule ^$ dist/index.html [L]

  # 3. Se o arquivo existir dentro de dist/, entregar ele (assets, etc)
  RewriteCond %{DOCUMENT_ROOT}/dist%{REQUEST_URI} -f
  RewriteRule ^(.*)$ /dist/$1 [L]

  # 4. Qualquer outra rota (React Router), entregar o index.html da dist
  RewriteCond %{REQUEST_URI} !^/dist/
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /dist/index.html [L]

  # Forçar tipos de arquivo (MIME Types)
  AddType application/javascript .js
  AddType text/css .css
</IfModule>
